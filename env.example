# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env file to a public repo.

# Gmail App Password required (NOT your normal Gmail password) — see README.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=marketplacetradeline@gmail.com
SMTP_PASS=your_16_char_app_password_here
FROM_EMAIL=marketplacetradeline@gmail.com
FROM_NAME=TradeLine Marketplace

# Shared secret the website sends in the X-API-Key header.
# Generate any long random string — example: openssl rand -hex 32
API_KEY=change_this_to_a_long_random_string

# Lock CORS down to your real domain once deployed, e.g. https://yourdomain.com
ALLOWED_ORIGIN=*

PORT=5000
DEBUG=0
